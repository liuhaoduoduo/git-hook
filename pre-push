#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Git pre-push 钩子脚本（Python 3 版本）

功能：在执行 push 前校验目标分支是否允许推送

规则：
  - 从 .git/hooks/push-branch-config 读取禁止推送分支（精确匹配）
  - 如果配置文件不存在或为空：默认拒绝所有 push
  - 命中禁止分支：阻止 push（返回非 0）
"""

import subprocess
import sys
from pathlib import Path


# 颜色定义
RED = '\033[0;31m'
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
BLUE = '\033[0;34m'
NC = '\033[0m'


def get_git_dir() -> str:
    """获取 Git 目录路径"""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--git-dir"],
            capture_output=True,
            text=True,
            check=True
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        return ""


def load_forbidden_branches(config_path: Path) -> set[str]:
    """读取禁止推送分支列表（精确匹配）"""
    forbidden: set[str] = set()
    try:
        with config_path.open(encoding='utf-8') as f:
            for raw in f:
                line = raw.strip()
                if not line or line.startswith('#'):
                    continue
                forbidden.add(line)
    except (OSError, IOError):
        return set()
    return forbidden


def extract_target_branches_from_stdin() -> list[str]:
    """从 pre-push 的 stdin 中提取目标分支名称"""
    branches: list[str] = []
    data = sys.stdin.read()
    if not data:
        return branches

    for line in data.splitlines():
        parts = line.strip().split()
        if len(parts) != 4:
            continue

        _local_ref, _local_sha, remote_ref, _remote_sha = parts
        if remote_ref.startswith('refs/heads/'):
            branches.append(remote_ref[len('refs/heads/'):])

    return branches


def main() -> int:
    git_dir = get_git_dir()
    if not git_dir:
        print(f"{RED}❌ 无法获取 Git 目录，已拒绝 push{NC}", file=sys.stderr)
        return 1

    config_file = Path(git_dir) / "hooks" / "push-branch-config"
    forbidden = load_forbidden_branches(config_file)

    # 默认拒绝策略：配置不存在或为空，直接拒绝 push
    if not config_file.exists() or not forbidden:
        print(f"{RED}❌ push 已被拒绝：禁推分支配置缺失或为空{NC}", file=sys.stderr)
        print(f"{YELLOW}⚠️  请在 {config_file} 中配置禁推分支列表{NC}", file=sys.stderr)
        return 1

    target_branches = extract_target_branches_from_stdin()

    blocked = [branch for branch in target_branches if branch in forbidden]
    if blocked:
        joined = ", ".join(sorted(set(blocked)))
        print(f"{RED}❌ push 已被拒绝：检测到禁止推送分支 -> {joined}{NC}", file=sys.stderr)
        return 1

    print(f"{GREEN}✅ 分支校验通过，允许 push{NC}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
