#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Git post-commit 钩子脚本（Python 3 版本）

功能：在 commit 成功后询问用户是否推送到远程仓库

触发场景：
  - git commit

注意：此脚本不会阻止 commit 操作（commit 已完成）
"""

import subprocess
import sys

# 颜色定义
RED = '\033[0;31m'
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
BLUE = '\033[0;34m'
NC = '\033[0m'  # No Color


def get_current_branch() -> str:
    """获取当前分支名称"""
    try:
        result = subprocess.run(
            ['git', 'rev-parse', '--abbrev-ref', 'HEAD'],
            capture_output=True,
            text=True,
            timeout=5
        )
        if result.returncode == 0:
            return result.stdout.strip()
    except (subprocess.TimeoutExpired, Exception):
        pass
    return ""


def has_remote_branch(branch: str) -> bool:
    """检查远程追踪分支是否存在"""
    try:
        result = subprocess.run(
            ['git', 'rev-parse', '--verify', f'origin/{branch}'],
            capture_output=True,
            timeout=5
        )
        return result.returncode == 0
    except (subprocess.TimeoutExpired, Exception):
        return False


def read_user_input(prompt: str) -> str:
    """从 /dev/tty 读取用户输入（Git hooks 的 stdin 被重定向，不能直接使用 input()）"""
    try:
        with open('/dev/tty', 'r') as tty:
            sys.stdout.write(prompt)
            sys.stdout.flush()
            return tty.readline().strip().lower()
    except (OSError, IOError):
        return ""


def main() -> int:
    current_branch = get_current_branch()
    if not current_branch:
        print(f"{RED}❌ 获取当前分支名称失败{NC}")
        return 0

    print(f"{BLUE}ℹ️  当前分支: {current_branch}{NC}")

    if not has_remote_branch(current_branch):
        print(f"{YELLOW}⚠️  分支 '{current_branch}' 没有对应的远程追踪分支，跳过推送提示{NC}")
        return 0

    answer = read_user_input(f"{BLUE}ℹ️  是否推送到 origin/{current_branch}？(y/n): {NC}")

    if answer == 'y':
        print(f"{BLUE}ℹ️  正在推送到 origin/{current_branch}...{NC}")
        try:
            result = subprocess.run(
                ['git', 'push', 'origin', current_branch],
                timeout=60
            )
            if result.returncode == 0:
                print(f"{GREEN}✅ 推送成功{NC}")
            else:
                print(f"{RED}❌ 推送失败 (退出码: {result.returncode}){NC}")
        except subprocess.TimeoutExpired:
            print(f"{RED}❌ 推送超时{NC}")
        except Exception as e:
            print(f"{RED}❌ 推送过程中出错: {e}{NC}")
    else:
        print(f"{YELLOW}⚠️  已跳过推送{NC}")

    return 0


if __name__ == "__main__":
    sys.exit(main())
