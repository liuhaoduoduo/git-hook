#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Git pre-rebase 钩子脚本（Python 3 版本）

功能：
  1. 检查 rebase 是否被 protected 规则允许
     - 若当前分支在保护列表中，仅允许 rebase 到自身分支（origin/<branch> 或 <branch>）
     - 其他分支的 rebase 会被拒绝
  2. 在 rebase 前自动执行编译操作

使用：
  作为 .git/hooks/pre-rebase 钩子自动调用
  参数：
    $1: upstream（要 rebase 到的目标分支）
    $2: branch（被 rebase 的分支，可选，仅在 rebase 其他分支时提供）

注意：
  - 若 rebase 被拒绝，会返回非零状态码（阻止 rebase）
  - 否则执行编译检查（失败也会阻止 rebase）
"""

import subprocess
import sys
from pathlib import Path

# 颜色定义
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
RED = '\033[0;31m'
BLUE = '\033[0;34m'
NC = '\033[0m'


def get_git_dir() -> str:
    """获取 Git 目录路径"""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--git-dir"],
            capture_output=True,
            text=True,
            check=True
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        return ""


def get_current_branch() -> str:
    """获取当前所在分支"""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True,
            text=True,
            check=True
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        return ""


def ref_to_branch_name(ref: str) -> str:
    """
    将 ref（可能是 commit SHA、branch name、origin/branch 等）转换为分支名
    
    支持的格式：
      - "abc123def" (commit SHA) -> 尝试通过 git describe 获取分支名
      - "main" (branch name) -> "main"
      - "origin/main" -> "main"
      - "refs/remotes/origin/main" -> "main"
    """
    if not ref:
        return ""
    
    ref = ref.strip()
    
    # 已经是简单的分支名
    if '/' not in ref:
        return ref
    
    # origin/branch 或 refs/remotes/origin/branch 格式
    if ref.startswith('origin/'):
        return ref.replace('origin/', '')
    if ref.startswith('refs/remotes/origin/'):
        return ref.replace('refs/remotes/origin/', '')
    
    # 尝试通过 git describe 转换 commit SHA 为 branch name
    try:
        result = subprocess.run(
            ["git", "describe", "--all", "--exact-match", ref],
            capture_output=True,
            text=True,
            check=True
        )
        described = result.stdout.strip()
        # git describe 返回 "remotes/origin/branch" 格式
        if described.startswith('remotes/origin/'):
            return described.replace('remotes/origin/', '')
        if described.startswith('origin/'):
            return described.replace('origin/', '')
        return described
    except subprocess.CalledProcessError:
        pass
    
    # 降级：返回原始 ref
    return ref


def load_protected_branches(config_path: Path) -> set:
    """
    读取分支保护配置
    
    返回：
      受保护分支的集合。空集表示配置为空（触发保护所有分支）
    """
    protected = set()
    
    if not config_path.exists():
        return protected
    
    try:
        with config_path.open(encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                
                # 跳过空行和注释
                if not line or line.startswith('#'):
                    continue
                
                # 添加分支到保护列表
                protected.add(line)
        
        return protected
    except Exception as e:
        print(f"{YELLOW}⚠️  警告：读取 protected 配置失败 ({e}){NC}", file=sys.stderr)
        return set()


def check_rebase_allowed(current_branch: str, upstream: str, protected_branches: set) -> bool:
    """
    检查当前 rebase 是否被允许
    
    规则：
      - 若当前分支不在保护列表中，允许
      - 若当前分支在保护列表中：
        * 若 upstream 等于当前分支（纯粹的同名分支或 origin/current_branch），允许
        * 否则禁止（拒绝其他分支的 rebase）
    
    Args:
      current_branch: 当前所在分支（如 'main'）
      upstream: rebase 的目标分支（如 'origin/main'、'feature-x' 等）
      protected_branches: 保护分支集合
    
    返回：
      True 允许，False 禁止
    """
    # 若配置为空或当前分支不在保护列表中，允许
    if not protected_branches or current_branch not in protected_branches:
        return True
    
    # 当前分支受保护，检查 upstream 是否来自自身
    # 支持以下 upstream 格式：main、origin/main、refs/remotes/origin/main
    upstream_branch = ref_to_branch_name(upstream)
    
    if upstream_branch == current_branch:
        return True
    
    # 其他情况禁止
    return False


def abort_rebase_with_error(current_branch: str, upstream: str, protected_branches: set) -> int:
    """
    输出详细错误消息，阻止 rebase
    
    返回：1（非零退出码，表示 rebase 被拒绝）
    """
    print()
    print(f"{RED}❌ Rebase 操作被禁止！{NC}")
    print()
    print(f"{BLUE}当前分支:{NC} {current_branch}")
    print(f"{BLUE}目标分支:{NC} {upstream}")
    print()
    
    if protected_branches:
        print(f"{BLUE}原因:{NC} 分支 '{current_branch}' 在保护列表中")
    else:
        print(f"{BLUE}原因:{NC} 所有分支都被保护（branch-protection.conf 为空）")
    
    print()
    print(f"{BLUE}规则:{NC}")
    print(f"  • 分支 '{current_branch}' 只允许 rebase 到自身（git rebase origin/{current_branch}）")
    print(f"  • 不允许 rebase 到其他分支（如 '{upstream}'）")
    print()
    print(f"{YELLOW}💡 提示:{NC} 如需修改此规则，请编辑 .git/hooks/branch-protection.conf")
    print()
    
    return 1


def main() -> int:
    """主函数：检查 rebase 保护规则，再执行编译"""
    
    # 获取 pre-rebase 的参数
    # $1: upstream (要 rebase 到的分支/commit)
    # $2: branch (被 rebase 的分支，仅在 rebase 其他分支时提供)
    upstream = sys.argv[1] if len(sys.argv) > 1 else ""
    rebasing_branch = sys.argv[2] if len(sys.argv) > 2 else None
    
    if not upstream:
        print(f"{YELLOW}⚠️  警告：无法获取 upstream 信息{NC}", file=sys.stderr)
        return 0  # 无法判断，允许继续
    
    # 获取当前分支（如果 $2 不存在，则使用当前分支）
    if rebasing_branch:
        current_branch = rebasing_branch
    else:
        current_branch = get_current_branch()
    
    if not current_branch:
        print(f"{YELLOW}⚠️  警告：无法获取当前分支名{NC}", file=sys.stderr)
        return 0  # 无法判断，允许继续
    
    # ========== 第一步：检查 rebase 保护规则 ==========
    git_dir = get_git_dir()
    if git_dir:
        config_path = Path(git_dir) / "hooks" / "branch-protection.conf"
        protected_branches = load_protected_branches(config_path)
        
        # 检查 rebase 是否被允许
        if not check_rebase_allowed(current_branch, upstream, protected_branches):
            # rebase 被拒绝
            return abort_rebase_with_error(current_branch, upstream, protected_branches)
    
    # ========== 第二步：执行编译脚本 ==========
    if not git_dir:
        print("Error: Could not determine git directory", file=sys.stderr)
        return 1
    
    build_script = Path(git_dir) / "hooks" / "build-on-hook.py"
    
    if not build_script.exists():
        print(f"Warning: Build script not found at {build_script}", file=sys.stderr)
        return 0
    
    try:
        result = subprocess.run(
            ["python3", str(build_script), "pre-rebase"],
            check=True
        )
        return result.returncode
    except subprocess.CalledProcessError as e:
        print(f"{RED}❌ 编译失败，已阻止 rebase。(退出码: {e.returncode}){NC}", file=sys.stderr)
        return e.returncode
    except Exception as e:
        print(f"Error: Failed to execute build script: {e}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
