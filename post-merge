#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Git post-merge 钩子脚本（Python 3 版本）

功能：在分支合并（包括 git pull 中的合并步骤）后自动执行编译操作

触发场景：
  - git merge <branch>
  - git pull origin <branch>（成功合并时）
  - git rebase --continue（完成时）


配置：
    编译命令列表在 .git/hooks/.build-config 文件中维护

注意：此脚本不会阻止 merge 操作，即使编译失败也会完成合并
"""

import subprocess
import sys
from pathlib import Path


def get_git_dir() -> str:
    """获取 Git 目录路径"""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--git-dir"],
            capture_output=True,
            text=True,
            check=True
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError as e:
        print(f"Error: Failed to get git directory: {e}", file=sys.stderr)
        return ""


def main() -> int:
    """主函数：调用公共编译脚本"""
    git_dir = get_git_dir()
    if not git_dir:
        print("Error: Could not determine git directory", file=sys.stderr)
        return 1
    
    build_script = Path(git_dir) / "hooks" / "build-on-hook.py"
    
    if not build_script.exists():
        print(f"Warning: Build script not found at {build_script}", file=sys.stderr)
        return 0
    
    try:
        subprocess.run(
            ["python3", str(build_script), "post-merge"],
            check=False
        )
    except Exception as e:
        print(f"Error: Failed to execute build script: {e}", file=sys.stderr)
        return 0  # 不阻止 merge 操作
    
    return 0


if __name__ == "__main__":
    sys.exit(main())
